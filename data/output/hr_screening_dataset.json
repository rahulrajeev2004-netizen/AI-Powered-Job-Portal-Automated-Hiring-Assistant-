{
  "dataset_id": "HR_SCREENING_AI_READY_V11",
  "version": "11.0.0",
  "status": "PRODUCTION_READY",
  "roles": [
    "Staff Nurse",
    "Software Engineer",
    "Sales Executive"
  ],
  "scoring_system": {
    "category_weights": {
      "Introduction": 0.05,
      "Education": 0.15,
      "Experience": 0.25,
      "Skills": 0.25,
      "Location": 0.1,
      "Salary": 0.1,
      "Notice Period": 0.1
    },
    "scoring_engine": {
      "execution_logic": {
        "question_score": "IF item_type == 'informational' THEN 0.0 ELSE IF evaluation_result == 'pass' THEN 1.0 ELSE IF evaluation_result == 'partial' THEN 0.5 ELSE 0.0",
        "question_weight": "IF item_type == 'required' THEN 1.0 ELSE IF item_type == 'preferred' THEN 0.5 ELSE 0.0",
        "category_score": "IF sum(question_weight_across_category) == 0.0 THEN 0.0 ELSE sum(question_score * question_weight) / sum(question_weight_across_category)",
        "base_score": "sum(category_score * category_weight)",
        "final_score": "max(0.0, min(1.0, base_score + resume_penalty))",
        "missing_required_penalty": "IF item_type == 'required' AND answer_is_missing THEN question_score = 0.0"
      },
      "confidence_logic": {
        "formula": "max(0.0, min(1.0, (0.3 * answer_completeness) + (0.3 * semantic_match_strength) + (0.2 * resume_consistency) + (0.2 * response_coverage)))",
        "variables": {
          "total_scorable_requirements": "COUNT(questions WHERE item_type == 'required')",
          "answered_scorable_requirements": "COUNT(answered_questions WHERE item_type == 'required')",
          "answer_completeness": "IF total_scorable_requirements == 0 THEN 1.0 ELSE answered_scorable_requirements / total_scorable_requirements",
          "total_scorable_questions": "COUNT(questions WHERE item_type != 'informational')",
          "semantic_match_strength": "IF total_scorable_questions == 0 THEN 0.0 ELSE sum(question_score) / total_scorable_questions",
          "resume_consistency": "max(0.0, 1.0 - abs(resume_penalty / max_penalty_cap))",
          "response_coverage": "IF total_scorable_questions == 0 THEN 1.0 ELSE COUNT(answered_questions WHERE item_type != 'informational') / total_scorable_questions"
        }
      },
      "dynamic_rules": {
        "experience_threshold_logic": "IF candidate_input >= ideal THEN 1.0 ELSE IF candidate_input >= min_required THEN 0.5 ELSE 0.0",
        "salary_evaluation_logic": "IF candidate_input <= budget_max AND candidate_input >= budget_min THEN 1.0 ELSE IF candidate_input <= (budget_max * 1.20) THEN 0.5 ELSE 0.0",
        "notice_period_matrix": [
          { "min": 0, "max": 15, "score": 1.0 },
          { "min": 16, "max": 30, "score": 0.7 },
          { "min": 31, "max": 60, "score": 0.5 },
          { "min": 61, "max": 90, "score": 0.3 },
          { "min": 91, "max": 999, "score": 0.0 }
        ]
      }
    },
    "decision_engine": {
      "SELECT": "final_score >= 0.75",
      "HOLD": "0.50 <= final_score < 0.75",
      "REJECT": "final_score < 0.50 OR knockout_triggered == true"
    },
    "knockout_handling": {
      "global_rule": "IMMEDIATE_TERMINATION",
      "effects": {
        "final_score": 0.0,
        "decision": "REJECT",
        "knockout_triggered": true,
        "stop_evaluation": true
      }
    }
  },
  "resume_validation": {
    "enabled": true,
    "checks": [
      "experience_consistency",
      "skill_match_with_resume",
      "education_validation"
    ],
    "resume_penalty_logic": {
      "calculation": "max(-0.4, sum(all_detected_mismatch_penalties))",
      "mismatch_types": {
        "experience_mismatch_major": -0.2,
        "experience_mismatch_minor": -0.1,
        "skill_mismatch_major": -0.15,
        "education_mismatch": -0.1
      },
      "max_penalty_cap": -0.4,
      "metrics": {
        "resume_match_score": "max(0.0, 1.0 - abs(sum(all_detected_mismatch_penalties) / -0.4))"
      }
    }
  },
  "structural_validation_rules": {
    "category_overlap_prevention": "A question_id MUST map to exactly ONE dimension. No cross-mapping permitted.",
    "experience_definition": "Experience = scope of responsibility, timelines, scale, and situational/scenario reasoning. Independent of specific toolkit.",
    "skills_definition": "Skills = tool usage, domain certifications, stack proficiency, and technical frameworks. Independent of duration.",
    "informational_isolation": "Questions with item_type='informational' MUST NOT influence category_score, semantic_match_strength, or resume_consistency."
  },
